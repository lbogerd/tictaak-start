{
	"name": "tictaak-start",
	"private": true,
	"type": "module",
	"version": "0.1.0",
	"engines": {
		"node": ">=24.6.0"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:local-db": "DB_PROVIDER=pglite pnpm db:seed && pnpm dev",
		"db:up": "bash scripts/db-up.sh",
		"db:down": "bash scripts/db-down.sh",
		"start": "node server.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"fix": "pnpm exec biome lint --write --unsafe && pnpm exec biome format --write",
		"comp:add": "pnpm dlx shadcn@latest add",
		"db:generate": "pnpm exec drizzle-kit generate",
		"db:push": "pnpm exec drizzle-kit push",
		"db:seed": "pnpm exec tsx src/lib/db/seed.ts",
		"db:reset": "pnpm run db:push && pnpm run db:seed",
		"db:studio": "pnpm exec drizzle-kit studio",
		"auth:create-user": "pnpm exec tsx scripts/create-user.ts",
		"release": "pnpm build && git push dokku main"
	},
	"dependencies": {
		"@fontsource/poppins": "5.2.7",
		"@radix-ui/react-popover": "1.1.15",
		"@radix-ui/react-select": "2.2.6",
		"@radix-ui/react-separator": "1.1.8",
		"@radix-ui/react-slot": "1.2.4",
		"@radix-ui/react-tabs": "1.1.13",
		"@t3-oss/env-core": "0.13.10",
		"@tailwindcss/vite": "4.2.2",
		"@tanstack/react-router": "1.168.2",
		"@tanstack/react-router-devtools": "1.166.11",
		"@tanstack/react-router-with-query": "1.130.17",
		"@tanstack/react-start": "1.167.3",
		"@tanstack/router-plugin": "1.167.3",
		"@vitejs/plugin-react": "6.0.1",
		"clsx": "2.1.1",
		"date-fns": "4.1.0",
		"drizzle-orm": "0.45.1",
		"lucide-react": "0.577.0",
		"next-themes": "0.4.6",
		"node-thermal-printer": "^4.6.0",
		"pg": "8.20.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"react": "19.2.4",
		"react-day-picker": "9.14.0",
		"react-dom": "19.2.4",
		"sonner": "2.0.7",
		"tailwind-merge": "3.5.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.2.2",
		"tailwindcss-animate": "1.0.7",
		"vite": "8.0.1",
		"vite-tsconfig-paths": "6.1.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@electric-sql/pglite": "0.4.1",
		"@testing-library/dom": "10.4.1",
		"@testing-library/react": "16.3.2",
		"@types/pg": "8.20.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"dotenv": "17.3.1",
		"drizzle-kit": "0.31.10",
		"fs-extra": "11.3.4",
		"husky": "9.1.7",
		"tsx": "4.21.0",
		"typescript": "5.9.3",
		"vitest": "4.1.0",
		"web-vitals": "5.1.0"
	},
	"packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b"
}
